APP_ENV=development
APP_NAME=go-grpc-starter
APP_VERSION=0.1.0
APP_WEB_URL=http://localhost:3000

SERVER_PORT=8080
DEFAULT_LANGUAGE=en

# gRPC server transport. Disable reflection on internet-facing deployments.
GRPC_REFLECTION=true
GRPC_MAX_RECV_BYTES=4194304
GRPC_MAX_SEND_BYTES=4194304
GRPC_CONNECTION_TIMEOUT=120s
GRPC_KEEPALIVE_TIME=2h
GRPC_KEEPALIVE_TIMEOUT=20s
GRPC_MAX_CONNECTION_IDLE=15m
GRPC_MAX_CONNECTION_AGE=30m
GRPC_MAX_CONNECTION_AGE_GRACE=5m
GRPC_KEEPALIVE_MIN_CLIENT_INTERVAL=5m
GRPC_SHUTDOWN_GRACE=20s

DB_HOST=localhost
DB_PORT=5432
DB_NAME=appdb
DB_SSL_MODE=disable
DB_TIMEZONE=UTC
DB_STATEMENT_TIMEOUT_MS=5000

DB_OWNER_USER=app_owner
DB_OWNER_PASSWORD=app_owner_password
DB_USER=app_owner
DB_PASSWORD=app_owner_password
DB_API_USER=app_api
DB_API_PASSWORD=app_api_password
DB_WORKER_USER=app_worker
DB_WORKER_PASSWORD=app_worker_password
DB_READONLY_USER=app_readonly
DB_READONLY_PASSWORD=app_readonly_password

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=password
REDIS_TIMEOUT=5s

STORAGE_ENDPOINT=localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=avatars
STORAGE_USE_SSL=false
STORAGE_PUBLIC_BASE_URL=http://localhost:9000/avatars

MAX_INACTIVITY_TIMEOUT=1440h
MAX_SESSION_AGE=4320h
MAX_DEVICES_PER_USER=5
ARGON2_MEMORY_KIB=65536
ARGON2_ITERATIONS=3
ARGON2_PARALLELISM=2
OAT_ACCESS_TOKEN_EXPIRY=30m
OAT_REFRESH_TOKEN_EXPIRY=720h

RESEND_API_KEY=
EMAIL_NOREPLY=noreply@example.com
EMAIL_SECURITY=security@example.com
EMAIL_NEWS=news@example.com
EMAIL_WORKER_CONCURRENCY=5

FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_FILE=secrets/firebase-dev.json

NOTIFICATION_WORKER_CONCURRENCY=10
NOTIFICATION_RETRY_MAX=3
NOTIFICATION_RETRY_DELAY=30s
NOTIFICATION_QUIET_HOURS_ENABLED=true

EVENTS_OUTBOX_INTERVAL=5s
EVENTS_OUTBOX_METRICS_INTERVAL=15s
EVENTS_OUTBOX_DRAIN_ON_API=false
